# LegiScan API Configuration
# Get your API key from: https://legiscan.com/legiscan
#
# The key is used SERVER-SIDE by the Netlify Function proxy
# (netlify/functions/legiscan.mts). Set it in the Netlify UI for production;
# `netlify dev` / `npm run web:netlify` picks it up from this file locally.
LEGISCAN_API_KEY=your_api_key_here

# Native (iOS/Android) builds can't use a relative proxy path, so point them
# at the deployed Netlify site:
EXPO_PUBLIC_LEGISCAN_PROXY_URL=https://your-site.netlify.app

# DEV ONLY: bypasses the proxy and calls LegiScan directly with this key.
# The key gets embedded in the JS bundle — never set this for production builds.
# EXPO_PUBLIC_LEGISCAN_API_KEY=your_api_key_here

# Firebase Configuration
# Get these values from your Firebase Console → Project Settings → General → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# OpenStates API Configuration
# Register for a key at: https://openstates.org/accounts/profile/
EXPO_PUBLIC_OPENSTATES_API_KEY=your_api_key_here

# BillTrack50 API Configuration (scorecard data)
EXPO_PUBLIC_BILLTRACK50_API_KEY=your_api_key_here
