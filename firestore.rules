rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user role
    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }
    
    // Helper function to check if user is admin or super admin
    function isAdmin() {
      return isAuthenticated() && 
             getUserRole(request.auth.uid) in ['admin', 'super_admin'];
    }
    
    // Helper function to check if user is super admin
    function isSuperAdmin() {
      return isAuthenticated() &&
             getUserRole(request.auth.uid) == 'super_admin';
    }

    // Gamification's totalPoints is otherwise fully client-writable, so
    // without this a user can set it to any value from the browser console.
    // Bounds: never decreases, and a single write can't jump by more than
    // 200 (the largest real action's point value, see constants/gamification.ts
    // ACTION_POINTS). Deliberately NOT an exact-match-per-action check —
    // that would reject legitimate writes if a user's local state drifts
    // from Firestore's current value (e.g. the app open on two devices),
    // and there's no rules emulator/test rig in this repo to safely verify
    // anything stricter. Exempted on create (resource == null) since account
    // creation always starts totalPoints at 0 in the app's own code.
    // NOTE: unlockedAchievements and actionCounts remain unvalidated —
    // deliberately out of scope, see CODEBASE_FINDINGS.md.
    function isValidPointsWrite() {
      return request.method == 'create' ||
             !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalPoints']) ||
             (request.resource.data.totalPoints is int &&
              request.resource.data.totalPoints >= resource.data.get('totalPoints', 0) &&
              request.resource.data.totalPoints <= resource.data.get('totalPoints', 0) + 200);
    }

    // Users collection
    match /users/{userId} {
      // Allow users to read their own document in full
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Allow users to write their own document, subject to the points bound above
      allow write: if isAuthenticated() && request.auth.uid == userId &&
                   isValidPointsWrite();

      // Allow admins and super admins to read all user documents
      allow read: if isAdmin();
      
      // Allow super admins to write (update/delete) any user document
      allow write: if isSuperAdmin();
      
      // Allow new user creation during signup
      allow create: if isAuthenticated() && 
                    request.auth.uid == userId &&
                    request.resource.data.keys().hasAll(['id', 'email', 'role', 'createdAt']) &&
                    request.resource.data.id == userId &&
                    request.resource.data.role == 'user';
      
      // Surveys subcollection - Users can read and write their own surveys
      match /surveys/{surveyId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
        
        // Allow admins to read all surveys
        allow read: if isAdmin();
      }

      // Saved Officials subcollection - Users can read and write their own saved officials
      match /savedOfficials/{officialId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Quiz subcollection - Users can read and write their own quiz data
      match /quizs/{docId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // Action History subcollection - Gamification action records
      match /actionHistory/{recordId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // Open Bills collection - Read by all authenticated users, Write by admins only
    match /openBills/{billId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Committee Emails collection - Read by all authenticated users, Write by admins only
    match /committeeEmails/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Bills collection - Public read, admin write
    match /bills/{billId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bill Category Tags - admin-curated overrides for the match engine
    match /billCategoryTags/{billNumber} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Testimonies collection - contains submitters' contact info (email,
    // address), so read/write are restricted to the owner or an admin.
    // `resource.data` doesn't exist yet on create, so create is checked
    // against the incoming `request.resource.data` instead.
    match /testimonies/{testimonyId} {
      allow read: if isAuthenticated() &&
                  (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                            (request.auth.uid == resource.data.userId || isAdmin());
    }
    
    // Notes collection - User can only access their own notes
    match /notes/{noteId} {
      allow read, write: if isAuthenticated() && 
                         request.auth.uid == resource.data.userId;
    }
    
    // Surveys collection - Public read, admin write
    match /surveys/{surveyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Survey responses - Users can only access their own responses
    match /survey_responses/{responseId} {
      allow read, write: if isAuthenticated() && 
                         request.auth.uid == resource.data.userId;
    }
    
    // Bill Talking Points collection - Read by all authenticated users, Write by admins only
    match /billTalkingPoints/{billId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      // Talking points subcollection
      match /points/{pointId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    
    // Legislator Ratings collection - Users can rate legislators
    match /legislatorRatings/{ratingId} {
      // Anyone can read ratings
      allow read: if true;
      
      // Users can only write their own ratings
      // Rating ID format: userId_legislatorId
      allow create: if isAuthenticated() && 
                    ratingId.matches('^' + request.auth.uid + '_.*$') &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.rating is int &&
                    request.resource.data.rating >= 1 &&
                    request.resource.data.rating <= 5;
      
      // Users can update their own ratings
      allow update: if isAuthenticated() && 
                    ratingId.matches('^' + request.auth.uid + '_.*$') &&
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.rating is int &&
                    request.resource.data.rating >= 1 &&
                    request.resource.data.rating <= 5;
      
      // Users can delete their own ratings
      allow delete: if isAuthenticated() && 
                    ratingId.matches('^' + request.auth.uid + '_.*$') &&
                    resource.data.userId == request.auth.uid;
    }
    
    // Legislator Rating Stats collection - Read by all, Write by admins
    // (no client code writes these today; recompute from legislatorRatings
    // server-side or in an admin tool if aggregates are needed)
    match /legislatorRatingStats/{legislatorId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
